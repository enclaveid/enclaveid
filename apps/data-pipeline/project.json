{
  "name": "data-pipeline",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/data-pipeline/data_pipeline",
  "targets": {
    "lock": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "command": "poetry lock --no-update",
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "outputs": ["{projectRoot}/poetry.lock"],
      "inputs": ["{projectRoot}/pyproject.toml"]
    },
    "export": {
      "executor": "@nxlv/python:run-commands",
      "dependsOn": ["lock"],
      "options": {
        "commands": [
          "poetry export --only vllm -f requirements.txt --output requirements.vllm.txt --without-hashes",
          "poetry export --only rapids -f requirements.txt --output requirements.rapids.txt --without-hashes",
          "poetry export --without rapids,vllm,dev -f requirements.txt --output requirements.prod.txt --without-hashes"
        ],
        "cwd": "apps/data-pipeline"
      },
      "cache": true,
      "outputs": [
        "{projectRoot}/requirements.rapids.txt",
        "{projectRoot}/requirements.vllm.txt",
        "{projectRoot}/requirements.prod.txt"
      ],
      "inputs": ["{projectRoot}/poetry.lock"]
    },
    "dev": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "command": "dagster dev --port 3001",
        "cwd": "apps/data-pipeline"
      }
    },
    "sqlacodegen": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "commands": [
          "sqlacodegen_v2 $API_DATABASE_URL --outfile data_pipeline/utils/database/db_models.py",
          "ruff format data_pipeline/utils/database/db_models.py"
        ],
        "parallel": false,
        "cwd": "apps/data-pipeline"
      }
    },
    "add": {
      "executor": "@nxlv/python:add",
      "options": {}
    },
    "update": {
      "executor": "@nxlv/python:update",
      "options": {}
    },
    "remove": {
      "executor": "@nxlv/python:remove",
      "options": {}
    },
    "build": {
      "executor": "@nxlv/python:build",
      "dependsOn": ["export"],
      "outputs": ["{workspaceRoot}/dist/apps/data-pipeline"],
      "options": {
        "outputPath": "{workspaceRoot}/dist/apps/data-pipeline",
        "publish": false,
        "lockedVersions": false,
        "bundleLocalDependencies": true
      },
      "cache": true
    },
    "install": {
      "executor": "@nxlv/python:install",
      "options": {
        "silent": false,
        "args": "",
        "cacheDir": ".cache/pypoetry",
        "verbose": false,
        "debug": false
      }
    },
    "install-base": {
      "executor": "@nxlv/python:install",
      "options": {
        "silent": false,
        "args": "--without vllm,rapids",
        "cacheDir": ".cache/pypoetry",
        "verbose": false,
        "debug": false
      }
    },
    "lint": {
      "executor": "@nxlv/python:ruff-check",
      "outputs": [],
      "options": {
        "lintFilePatterns": ["data_pipeline", "tests"]
      }
    },
    "test": {
      "executor": "@nxlv/python:run-commands",
      "outputs": [
        "{workspaceRoot}/reports/apps/data-pipeline/unittests",
        "{workspaceRoot}/coverage/apps/data-pipeline"
      ],
      "options": {
        "command": "poetry run pytest tests/",
        "cwd": "apps/data-pipeline"
      }
    },
    "container-rapids": {
      "executor": "@nx-tools/nx-container:build",
      "dependsOn": ["build"],
      "options": {
        "engine": "docker",
        "push": true,
        "file": "apps/data-pipeline/Dockerfile.rapids",
        "platforms": ["linux/amd64"],
        "metadata": {
          "images": ["docker.io/enclaveid/data-pipeline-rapids"],
          "tags": [
            "type=schedule",
            "type=ref,event=branch",
            "type=ref,event=tag",
            "type=ref,event=pr",
            "type=sha,prefix=sha-"
          ]
        },
        "cache-from": ["type=local,src=/tmp/.buildx-cache"],
        "cache-to": ["type=local,dest=/tmp/.buildx-cache-new,mode=max"]
      }
    },
    "container-vllm": {
      "executor": "@nx-tools/nx-container:build",
      "dependsOn": ["build"],
      "options": {
        "engine": "docker",
        "push": true,
        "file": "apps/data-pipeline/Dockerfile.vllm",
        "platforms": ["linux/amd64"],
        "metadata": {
          "images": ["docker.io/enclaveid/data-pipeline-vllm"],
          "tags": [
            "type=schedule",
            "type=ref,event=branch",
            "type=ref,event=tag",
            "type=ref,event=pr",
            "type=sha,prefix=sha-"
          ]
        },
        "cache-from": ["type=local,src=/tmp/.buildx-cache"],
        "cache-to": ["type=local,dest=/tmp/.buildx-cache-new,mode=max"]
      }
    },
    "container": {
      "executor": "@nx-tools/nx-container:build",
      "dependsOn": ["build"],
      "options": {
        "engine": "docker",
        "push": true,
        "file": "apps/data-pipeline/Dockerfile.base",
        "platforms": ["linux/amd64"],
        "metadata": {
          "images": ["docker.io/enclaveid/data-pipeline-base"],
          "tags": [
            "type=schedule",
            "type=ref,event=branch",
            "type=ref,event=tag",
            "type=ref,event=pr",
            "type=sha,prefix=sha-"
          ]
        },
        "cache-from": ["type=local,src=/tmp/.buildx-cache"],
        "cache-to": ["type=local,dest=/tmp/.buildx-cache-new,mode=max"]
      }
    },
    "container-jupyter": {
      "executor": "@nx-tools/nx-container:build",
      "dependsOn": ["build"],
      "options": {
        "engine": "docker",
        "push": true,
        "file": "apps/data-pipeline/notebooks/Dockerfile",
        "platforms": ["linux/amd64"],
        "metadata": {
          "images": ["docker.io/enclaveid/jupyter"],
          "tags": [
            "type=schedule",
            "type=ref,event=branch",
            "type=ref,event=tag",
            "type=ref,event=pr",
            "type=sha,prefix=sha-"
          ]
        }
      }
    }
  },
  "tags": []
}
