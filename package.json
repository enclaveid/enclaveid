{
  "name": "@enclaveid/enclaveid",
  "version": "0.0.0",
  "license": "MIT",
  "nx": {
    "targets": {
      "helm-chart": {
        "dependsOn": [
          "containers",
          "aux-containers"
        ],
        "inputs": [
          "{workspaceRoot}/k8s/helm"
        ],
        "outputs": [
          "{workspaceRoot}/k8s/renders"
        ]
      },
      "deploy": {
        "dependsOn": [
          "helm-chart"
        ],
        "inputs": [
          "{workspaceRoot}/k8s/renders"
        ]
      },
      "undeploy": {
        "inputs": [
          "{workspaceRoot}/k8s/renders"
        ]
      }
    }
  },
  "scripts": {
    "containers": "nx run-many --target=container --parallel --output-style=dynamic",
    "aux-containers": "nx exec -- scripts/build_aux_containers.sh",
    "bump-version": "nx exec -- scripts/bump_project_version.sh",
    "helm-chart": "nx exec -- k8s/scripts/render_chart_dev.sh",
    "deploy": "kubectl apply --context=$CONTEXT -f k8s/renders/k8s-configs.yaml -f k8s/renders/kata-configs.yaml",
    "undeploy": "kubectl delete --context=$CONTEXT -f k8s/renders/k8s-configs.yaml -f k8s/renders/kata-configs.yaml",
    "clean-chrome": "kubectl delete --context=$CONTEXT pods -n default -l class=chrome-pod; kubectl delete services -n default -l class=chrome-pod",
    "sync-dagster": "nx exec -- scripts/sync_dagster.sh",
    "cloc": "cloc --vcs git --exclude-list-file=.clocignore"
  },
  "private": true,
